generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  password  String
  
  createdAt DateTime @default(now())
}

model Motorista {
  id             String      @id @default(uuid())
  nomeMotorista  String
  cpf            String      @unique
  telefone       String
  status         String      @default("DISPONIVEL")
  modeloVeiculo  String
  placaVeiculo   String      @unique
  capacidadeMax  Float
  createdAt      DateTime    @default(now())
  encomendas     Encomenda[]
}

model Encomenda {
  id              String   @id @default(uuid())
  nomeCliente     String
  pesoPacote      Float
  largura         Float
  altura          Float
  comprimento     Float
  destinoDoPacote String
  status          String   @default("AGUARDANDO_COLETA") // renomeado de statusColeta
  motoristaId     String?                                 // 👈 novo
  motorista       Motorista? @relation(fields: [motoristaId], references: [id]) // 👈 novo
  createdAt       DateTime @default(now())
}